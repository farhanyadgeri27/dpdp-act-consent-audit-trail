MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ── AI Service ───────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:5000
GROQ_API_KEY=your_groq_api_key

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@internship.com